# Copy to backend/.env and fill in. .env is gitignored — never commit it.
#
# RECOMMENDED SPLIT
#   - Secrets (tokens/passwords) live here in the environment.
#   - Applicative (non-secret) configuration — watched repos, verify knobs,
#     backend routing — belongs in config.toml. Copy config.toml.example and
#     see docs/configuration.md.
# Every KESTREL_* var below still works, but the TOML file is the preferred
# home for non-secret settings and wins where it sets a key.

# Point kestrel at the TOML config file (recommended). Uncomment and adjust:
# KESTREL_CONFIG_FILE=config.toml

# --- secrets (keep these in the environment) --------------------------------
# GitHub token: unlocks issue ingestion, clone/push, and PRs.
KESTREL_GITHUB_TOKEN=
# Webhook HMAC shared secret; empty disables the webhook path. Never logged.
KESTREL_WEBHOOK_SECRET=
# Jira API token / PAT (used with jira_email for basic, or as a bearer PAT).
KESTREL_JIRA_API_TOKEN=
# Code-host token / PAT; falls back to KESTREL_GITHUB_TOKEN when code_host=github.
KESTREL_CODE_HOST_TOKEN=

# --- applicative config: prefer config.toml ---------------------------------
# The settings below now live in config.toml (see config.toml.example) — set
# them there. They remain valid as env vars too and are left commented here
# purely as a fallback reference; uncomment only if you are not using the file.
# KESTREL_WATCHED_REPOS=                 # comma-separated or JSON owner/name list
# KESTREL_TRIGGER_LABEL=kestrel
# KESTREL_RECONCILE_INTERVAL_SECONDS=300
# KESTREL_VERIFY_CHECKS=                 # JSON list, e.g. ["uv run pytest -q"]
# KESTREL_MAX_VERIFY_ITERATIONS=3

# --- environment-only settings (no config.toml equivalent yet) --------------
# Uvicorn bind address / port and the dev auto-reload toggle.
KESTREL_HOST=0.0.0.0
KESTREL_PORT=8000
KESTREL_RELOAD=0
KESTREL_CLAUDE_BIN=claude
KESTREL_WORKSPACE_ROOT=./.kestrel-workspaces
KESTREL_PERMISSION_MODE=acceptEdits
KESTREL_GITHUB_API_BASE=https://api.github.com
KESTREL_GIT_BASE=https://github.com
# Public URL of the kestrel UI, used to build clickable gate-notification
# deep-links. Leave empty to post comments without a link.
KESTREL_PUBLIC_BASE_URL=

# Jira ingestion (feature 003). Leave jira_base_url empty to disable polling.
# Poll-only (no inbound endpoint). jira_auth: basic (Cloud email+API token) or
# bearer (Server/DC PAT). jira_repo_field names the RFC field holding the target
# owner/name[@base_branch]. The token itself is a secret — see above.
KESTREL_JIRA_BASE_URL=
KESTREL_JIRA_AUTH=basic
KESTREL_JIRA_EMAIL=
KESTREL_JIRA_PROJECT=
# Extra JQL AND-ed onto project="<key>", e.g. status = "Ready for Kestrel"
KESTREL_JIRA_JQL_FILTER=
KESTREL_JIRA_REPO_FIELD=
KESTREL_JIRA_POLL_INTERVAL_SECONDS=300

# Code host for Jira-resolved repos (self-hostable): github | gitlab | gitea.
# gitlab/gitea point at an on-prem instance (see KESTREL_CODE_HOST_TOKEN above).
KESTREL_CODE_HOST=github
KESTREL_CODE_HOST_BASE_URL=

# Logging: text (human-readable, default) or json (one JSON per line)
KESTREL_LOG_LEVEL=info
KESTREL_LOG_FORMAT=text
