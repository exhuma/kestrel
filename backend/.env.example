# Copy to backend/.env and fill in. .env is gitignored — never commit it.
#
# RECOMMENDED SPLIT
#   - Secrets (tokens/passwords) live here in the environment.
#   - Applicative (non-secret) configuration — task sources, verify knobs,
#     backend routing — belongs in config.toml. Copy config.toml.example and
#     see docs/configuration.md.
# Task sources (GitHub / Jira) are configured in config.toml as a
# [[task_sources]] list; each entry names the env var holding its token below.

# Point kestrel at the TOML config file (recommended). Uncomment and adjust:
# KESTREL_CONFIG_FILE=config.toml

# --- secrets (keep these in the environment) --------------------------------
# These are the default token env vars a task source uses (override per source
# with `token_env` in config.toml). A source's token is read from here by name;
# the TOML file stays secret-free.
# GitHub token: unlocks issue ingestion, clone/push, and PRs. Default token_env
# for a github source.
KESTREL_GITHUB_TOKEN=
# Webhook HMAC shared secret; empty disables the webhook path. Never logged.
KESTREL_WEBHOOK_SECRET=
# Jira API token / PAT. Default token_env for a jira source (basic: with email;
# bearer: as a PAT).
KESTREL_JIRA_API_TOKEN=
# Code-host token / PAT for a jira source's resolved repos; falls back to
# KESTREL_GITHUB_TOKEN when its code_host is github.
KESTREL_CODE_HOST_TOKEN=

# --- applicative config: use config.toml ------------------------------------
# Task sources ([[task_sources]]), the poll cadence (poll_interval_seconds),
# verify knobs, and backend routing live in config.toml (see
# config.toml.example and docs/configuration.md). They are file-only or
# file-preferred — set them there, not here.

# --- environment-only settings ----------------------------------------------
# Uvicorn bind address / port and the dev auto-reload toggle.
KESTREL_HOST=0.0.0.0
KESTREL_PORT=8000
KESTREL_RELOAD=0
KESTREL_CLAUDE_BIN=claude
KESTREL_WORKSPACE_ROOT=./.kestrel-workspaces
KESTREL_PERMISSION_MODE=acceptEdits
KESTREL_GITHUB_API_BASE=https://api.github.com
KESTREL_GIT_BASE=https://github.com
# Public URL of the kestrel UI, used to build clickable gate-notification
# deep-links. Leave empty to post comments without a link.
KESTREL_PUBLIC_BASE_URL=

# Jira instance, JQL, repo resolution, and code host are configured per source
# in config.toml ([[task_sources]] with type = "jira") — not here. Only the
# Jira/code-host tokens live in the environment (see the secrets section above).

# Logging: text (human-readable, default) or json (one JSON per line)
KESTREL_LOG_LEVEL=info
KESTREL_LOG_FORMAT=text
