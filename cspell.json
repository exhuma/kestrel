{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en,en-GB",
  "files": [
    "README.md",
    "docs/*.md",
    "backend/app/**/*.py",
    "frontend/src/**/*.{ts,vue}"
  ],
  "ignorePaths": [
    "**/node_modules/**",
    "**/dist/**",
    "**/.venv/**"
  ],
  "words": [
    "aclose", "aread", "ASGI", "changeme", "codegen", "conftest", "contextvar",
    "coro", "creds", "customfield", "dedup", "deeplink", "deepseek",
    "dispatchable", "Dockerisation",
    "dotenv", "ecard", "ensembling", "exhuma", "extraheader", "fastapi",
    "Forgejo", "formedness", "ghlink", "gitea", "glanceable", "gpgsign",
    "grayscale", "hostable", "iconsets", "idempotently",
    "HEALTHCHECK", "healthchecks", "healthz", "HMAC", "hrefs", "httpx",
    "infosec", "Instrumentor", "KEEPALIVE", "keepalives", "kwargs", "livez",
    "multiedit",
    "nosniff", "notebookedit", "notif", "ntfy", "Okabe", "ollama",
    "opencode", "pinentry", "Planka", "PROCS", "pydantic", "pyproject",
    "pytest", "qbadge", "qblock", "qform", "qgroup", "qtab", "qtabs", "readyz",
    "renamespaced", "reraise", "rgba", "runbook", "runbooks", "savestatus",
    "scard",
    "sessionmaker", "sqlalchemy", "stageroot", "substep", "taskfile",
    "todowrite", "topbar", "traceparent", "uiux", "unconfigured",
    "parseable", "unloadable", "unparseable",
    "unlabeled", "uvicorn", "viewnav", "Vite", "Vuetify", "webfetch",
    "webhook", "worktree", "Zammad"
  ]
}
