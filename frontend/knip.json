{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["tests/**/*.{test,spec}.ts", "tests/support/**/*.ts"],
  "project": ["src/**/*.{ts,vue}"],
  "rules": {
    "files": "error",
    "dependencies": "error",
    "unlisted": "error",
    "binaries": "error",
    "unresolved": "error",
    "exports": "warn",
    "types": "warn",
    "nsExports": "warn",
    "nsTypes": "warn",
    "enumMembers": "warn",
    "duplicates": "warn"
  }
}
