# Frontend build-time configuration (Vite). Copy to `.env.local` (gitignored)
# for local development, or pass as Docker build args for packaged images.
# Only VITE_-prefixed variables are exposed to the SPA.

# Full URL of the GitHub repository. When set, an unobtrusive "Source code"
# link appears in the header; leave empty to hide it.
VITE_GITHUB_REPO_URL=

# Base URL of the backend API. Empty means same-origin (the backend serves the
# bundle in the packaged image); defaults to http://localhost:8000 in dev.
VITE_API_BASE=
