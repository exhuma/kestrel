# Frontend build-time configuration (Vite). Copy to `.env.local` (gitignored)
# for local development, or pass as Docker build args for packaged images.
# Only VITE_-prefixed variables are exposed to the SPA.

# Full URL of the GitHub repository. When set, an unobtrusive "Source code"
# link appears in the header; leave empty to hide it.
VITE_GITHUB_REPO_URL=

# Base URL of the backend API.
#   - Left unset (including a verbatim copy of this file) the app uses the
#     in-code default http://localhost:8000, so run-from-source dev works with
#     no configuration.
#   - An *empty* value means same-origin — used by the packaged image, which
#     serves the bundle itself. Only set it empty for that build.
#   - Any explicit URL overrides both.
# Uncomment and set only to point the SPA at a non-default backend:
# VITE_API_BASE=http://localhost:8000
