# kestrel configuration.
#
# Point kestrel at this file with KESTREL_CONFIG_FILE (see README). Copy to
# `config.toml` and edit. It holds two kinds of settings:
#
#   1. Applicative (non-secret) config — watched repos, cadences, verify
#      knobs. These may also be given as KESTREL_* env vars; this file wins
#      where it sets a key, and env fills in the rest.
#   2. Backend routing (`default_session_backend`, `[step_backends]`,
#      `[[backends]]`). These are file-only — the matching env vars are
#      inert.
#
# SECRETS STAY IN THE ENVIRONMENT: KESTREL_GITHUB_TOKEN,
# KESTREL_WEBHOOK_SECRET, KESTREL_JIRA_API_TOKEN, KESTREL_CODE_HOST_TOKEN, and
# per-backend api keys/passwords are never put here (except a backend's inline
# `api_key`/`password`, which is tolerated only because this file is
# gitignored).
#
# NOTE ON base_url IN DOCKER: inside the container `localhost` is the
# container, not the host. To reach a backend running on the Docker host,
# use http://host.docker.internal:PORT instead of http://localhost:PORT
# (the published docker-compose.yml already maps host.docker.internal).
# The localhost examples below are correct when running kestrel from source.

# --- applicative config -----------------------------------------------------
# Single cadence (seconds) governing how often every task source is re-checked
# (the GitHub reconcile backstop and the Jira poll alike).
poll_interval_seconds = 300
# Shell commands run in the run's worktree as verify evidence. Empty ⇒
# judgment-only.
verify_checks = ["uv run pytest -q"]
# Max code↔verify iterations before the loop escalates.
max_verify_iterations = 3

# --- task sources -----------------------------------------------------------
# Each [[task_sources]] entry declares where kestrel pulls work from. Secrets
# stay in the environment: an entry names the env var holding its token via
# `token_env` (defaulting per type). Add more entries — including a second of
# the same type — as needed.

# GitHub: watch a repo allow-list for issues carrying the trigger label. Pair
# with KESTREL_WEBHOOK_SECRET in the environment to accept webhook deliveries.
[[task_sources]]
type = "github"
watched_repos = ["owner/name"]
trigger_label = "kestrel"
# token_env = "KESTREL_GITHUB_TOKEN"   # optional (this is the default)

# Jira: poll one instance with a whole JQL query (you write the project clause
# yourself). The target repo is resolved from `repo_field` or a web link titled
# `repo_link_text`. `key` is the issue-key prefix, used only to scope dismissals.
# [[task_sources]]
# type = "jira"
# base_url = "https://acme.atlassian.net"
# auth = "basic"                       # "basic" (Cloud) | "bearer" (Server/DC PAT)
# email = "me@acme.com"
# jql = 'project = "RFC" AND status = "Ready"'
# key = "RFC"
# token_env = "KESTREL_JIRA_API_TOKEN"  # optional (default)
# verify_ssl = false                    # skip TLS cert checks on the Jira/code-host
#                                       # REST calls (self-signed/internal CA)
# repo_field = "customfield_10050"      # optional; else a titled web link is used
# repo_link_text = "Repository"         # web-link title to match (default)
# code_host = "github"                  # "github" | "gitlab" | "gitea"
# code_host_base_url = ""               # for a self-hosted gitlab/gitea
# code_host_token_env = "KESTREL_CODE_HOST_TOKEN"

# --- backend routing --------------------------------------------------------
# Backend used for ad-hoc /api/sessions dispatch.
default_session_backend = "claude"

# Per-workflow-step backend (step -> backend id); steps omitted use the
# default above. `implement` edits a per-run workspace, so keep it on an
# agent that honours the working directory (claude).
[step_backends]
refine    = "claude"
plan      = "claude"
implement = "claude"

# --- backends ---------------------------------------------------------------
# Each [[backends]] entry: id, type (claude_cli | openai_compat | opencode),
# and per-type fields (base_url, model, api_key_env, username).

[[backends]]
id = "claude"
type = "claude_cli"

# A self-hosted OpenAI-compatible LLM (Ollama, vLLM, LocalAI, …). Text-only.
# `api_key` (or api_key_env) sets a bearer token if the endpoint needs one.
# `timeout` (seconds) is worth raising for big/slow models.
[[backends]]
id = "local"
type = "openai_compat"
base_url = "http://localhost:11434/v1"
model = "llama3.1:8b"
# api_key = "sk-…"
# timeout = 300

# opencode via `opencode serve`. `model` is "provider/model". For a secured
# server (OPENCODE_SERVER_PASSWORD), give the password inline via `password`
# (this file is gitignored) or via `api_key_env` (name of an exported env
# var). `username` defaults to "opencode".
[[backends]]
id = "oc"
type = "opencode"
base_url = "http://localhost:4096"
model = "anthropic/claude-sonnet-4"
# username = "opencode"
# password = "changeme"
# api_key_env = "OPENCODE_SERVER_PASSWORD"   # alternative to `password`
